<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="// SECOND BRAIN"
            android:textColor="#ff5500"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/widget_title"
            android:text="// ACTIVE NEURAL QUEUE"
            android:textColor="#888899"
            android:textSize="10sp"
            android:textStyle="italic" />
    </RelativeLayout>

    <!-- Reminders List Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/reminder_item_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• [System initialized &amp; syncing]"
            android:textColor="#ddddff"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/reminder_item_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#ddddff"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/reminder_item_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#ddddff"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Quick Ingestion Action Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/widget_sync_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LAST UPDATE: --:--"
            android:textColor="#555566"
            android:textSize="9sp" />

        <Button
            android:id="@+id/btn_quick_note"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:background="@drawable/widget_button"
            android:text="⚡ QUICK VOX"
            android:textColor="#ff5500"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
